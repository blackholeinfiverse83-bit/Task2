# ===========================================
# Auth DB — shared with the other project
# ===========================================
MONGODB_AUTH_URI=mongodb+srv://<user>:<pass>@<cluster>/auth_db

# ===========================================
# News DB — this project's own database
# ===========================================
MONGODB_NEWS_URI=mongodb+srv://<user>:<pass>@<cluster>/news_db

# ===========================================
# JWT Config — must match the other project
# ===========================================
JWT_SECRET=your-shared-jwt-secret-change-this
JWT_EXPIRES_IN=7d

# ===========================================
# Backend APIs (existing)
# ===========================================
NEXT_PUBLIC_NOOPUR_API_BASE=http://localhost:8000
NEXT_PUBLIC_SANKALP_API_BASE=http://localhost:8000
